{
    "trailingComma": "none",
    "printWidth": 120,
    "tabWidth": 4,
    "semi": true,
    "singleQuote": true,
    "overrides": [
        {
            "files": "**/*.{cls,trigger,apex}",
            "options": {
                "parser": "apex",
                "tabWidth": 4
            }
        },
        {
            "files": "**/*.html",
            "options": {
                "parser": "lwc"
            }
        }
    ]
}